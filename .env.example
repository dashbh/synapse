# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Used by backend for embeddings (text-embedding-ada-002) and answer generation (gpt-4o-mini)
OPENAI_API_KEY=sk-...

# ── Supabase (hosted) ──────────────────────────────────────────────────────────
# PostgreSQL + pgvector — no local DB container needed
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ── Backend server ─────────────────────────────────────────────────────────────
PORT=8000

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed by FastAPI CORS middleware.
# Docker Compose overrides this per profile via the environment: block.
# For bare local dev (outside Docker) this default is used as-is.
CORS_ORIGINS=http://localhost:3000

# ── Frontend → Backend proxy ───────────────────────────────────────────────────
# Where Next.js server-side proxy routes forward to FastAPI.
# Docker Compose overrides this to use internal Docker DNS (http://backend-dev:8000).
# For bare local dev (outside Docker) set this to http://localhost:8000.
BACKEND_URL=http://localhost:8000
